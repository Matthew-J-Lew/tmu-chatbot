# Copy this file to .env and fill in your values.
# Never commit .env to Git.

# This repo is designed to be configured via environment variables.
# For most deployments (including docker compose), .env is the single source of truth
# for tuning knobs and infrastructure settings.


# ============================================================
# Core infrastructure
# ============================================================

# ---- Postgres (pgvector) ----
PGHOST=pg
PGPORT=5432
PGDATABASE=ragdb
PGUSER=rag
PGPASSWORD=rag

# ---- Redis (caching) ----
REDIS_URL=redis://redis:6379/0


# ============================================================
# Runtime knobs (biggest answer-quality impact)
# ============================================================

# ---- Retrieval (RAG) ----
RAG_NUM_CANDIDATES=50
RAG_TOP_K=12
RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Hybrid scoring inside Postgres (vector vs keyword)
HYBRID_WEIGHT_VECTOR=0.6
HYBRID_WEIGHT_TEXT=0.4

# ---- Prompt packing limits (character-based) ----
MAX_CHUNK_CHARS=2200
MAX_CONTEXT_CHARS=40000

# ---- Caching ----
CACHE_TTL_RESPONSE=3600
CACHE_TTL_RETRIEVAL=3600

# ---- Concurrency ----
MAX_CONCURRENT_LLM=2

# ---- LLM selection ----
# Use Azure OpenAI (recommended) or fall back to the local Ollama container.
LLM_PROVIDER=azure
# Optional: if the primary provider fails, try this provider once.
LLM_FALLBACK_PROVIDER=ollama

# ---- Azure OpenAI ----
# Endpoint + deployment match the Faculty of Arts Azure OpenAI resource.
AZURE_OPENAI_ENDPOINT=https://arts-chatbot-openai.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_API_KEY=REPLACE_ME

# Generation knobs
AZURE_OPENAI_MAX_TOKENS=2048
AZURE_OPENAI_TEMPERATURE=0.0
AZURE_OPENAI_TIMEOUT_SECONDS=60

# ---- Ollama (local dev / fallback) ----
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_NUM_PREDICT=512
OLLAMA_TEMPERATURE=0.1
OLLAMA_TOP_P=0.9
OLLAMA_TIMEOUT_SECONDS=90
OLLAMA_MAX_RETRIES=2

# ---- CORS ----
# Comma-separated list of allowed origins for the web widget.
CORS_ALLOW_ORIGINS=https://www.torontomu.ca


# ============================================================
# Ingestion + indexing knobs (re-ingest required after changing)
# ============================================================

# Embedding model used for BOTH ingestion and runtime query embeddings.
# Must match the DB vector dimension (schema.sql uses VECTOR(384) by default).
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Chunking knobs (token-based)
CHUNK_TOKEN_SIZE=400
CHUNK_TOKEN_OVERLAP=80


# ---- Ingestion: JS-heavy pages ----
# Enable Playwright-based rendering during ingestion to handle accordion/dropdown/SPA pages.
INGEST_USE_PLAYWRIGHT=true
# If true, always use Playwright for HTML pages (slower, but most reliable).
INGEST_PLAYWRIGHT_ALWAYS=false
# If true, use Playwright when static fetch fails or extracts too little text.
INGEST_PLAYWRIGHT_FALLBACK=true
# Minimum extracted characters before we consider the page "too empty" and fallback to Playwright.
INGEST_MIN_EXTRACTED_CHARS=400
# Attempt to expand common accordions (buttons with aria-expanded=false, <details> tags) before extracting.
PLAYWRIGHT_EXPAND_ACCORDIONS=true


# ============================================================
# Crawl / pipeline knobs (ops)
# ============================================================

CRAWL_PROFILE=arts
CRAWL_RPS=1.0
CRAWL_ENABLE_SITEMAPS=true
CRAWL_CALENDAR_ALLOWED_YEARS=2025-2026,2026-2027
INGEST_LIMIT=500

# Pipeline scheduler container (optional)
PIPELINE_PROFILES=arts,arts_calendar,tmu_core
PIPELINE_INTERVAL_SECONDS=21600
